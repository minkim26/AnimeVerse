# Copy to .env.local (for `npm run dev` outside Docker) or .env.production
# (for `docker compose up`) and fill in real values. Never commit either file.

# Prisma connection string. Inside Docker Compose, host is the "postgres"
# service name; outside Docker, use localhost.
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/animeverse

# Used by the official postgres Docker image to initialize the database.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=animeverse

# Secret used to sign/verify JWTs. Use a long random value in real deployments.
JWT_SECRET=change-me

PORT=8000

# Supabase project created for AnimeVerse (Storage only). SUPABASE_KEY must
# be the service_role key; it is only ever used server-side and must never
# be shipped to the frontend.
SUPABASE_URL=
SUPABASE_KEY=

# RabbitMQ connection string. Inside Docker Compose, host is the "rabbitmq"
# service name.
RABBITMQ_URL=amqp://localhost

# Redis connection string, used for rate limiting and response caching.
# Inside Docker Compose, host is the "redis" service name.
REDIS_URL=redis://localhost:6379

# Origin allowed to make cross-origin requests to this API (CORS). Should
# match wherever the frontend is actually served from.
FRONTEND_URL=http://localhost:5173
